# Which LLM backend to use: groq | openai | ollama
# Groq is the default -- free tier, no credit card, and (unlike Ollama)
# works unmodified inside GitHub Actions for Phase 5's CI pipeline.
LLM_PROVIDER=groq

# --- Groq (default) ---
# Get a free key at https://console.groq.com (no credit card required)
GROQ_API_KEY=gsk_your-key-here

# --- OpenAI (optional, if you set LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here

# --- Ollama (optional, if you set LLM_PROVIDER=ollama) ---
# No key needed -- just run `ollama serve` locally first.
# Also change prompts/v1.yaml's `model:` field to a model you've pulled,
# e.g. "llama3.1" (run `ollama pull llama3.1` first).
